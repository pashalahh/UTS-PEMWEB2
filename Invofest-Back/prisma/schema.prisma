generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  
  events    Event[]

  @@map("categories")
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  location    String
  dateEvent   DateTime @map("date_event")
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  categoryId  Int      @map("category_id")
  pembicaraId Int?     @map("pembicara_id")

  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  pembicara   Pembicara? @relation(fields: [pembicaraId], references: [id], onDelete: SetNull)

  @@map("events")
}

model Pembicara {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  image     String
  createdAt DateTime @default(now()) @map("created_at")
  
  events    Event[]

  @@map("pembicara") 
}